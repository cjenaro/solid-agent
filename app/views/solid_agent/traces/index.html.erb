<h1>Traces</h1>

<% running_traces = @traces.select { |t| t.status == 'running' || t.status == 'pending' } %>
<% if running_traces.any? %>
  <div style="margin-bottom:1rem; padding:0.75rem 1rem; background:#fef3c7; border-radius:0.5rem; font-size:0.875rem; display:flex; align-items:center; gap:1rem;">
    <span><strong><%= running_traces.size %></strong> trace(s) still running/pending</span>
    <%= button_to "Cancel all running", solid_agent.cancel_running_traces_path, method: :patch, class: "btn-cancel", form: { style: "display:inline-block;" } %>
  </div>
<% end %>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Agent</th>
      <th>Status</th>
      <th>Tokens</th>
      <th>Cost</th>
      <th>Iterations</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% @traces.each do |trace| %>
      <tr>
        <td><%= link_to trace.id, solid_agent.trace_path(trace) %></td>
        <td><%= trace.agent_class %></td>
        <td><span class="badge badge-<%= trace.status %>"><%= trace.status %></span></td>
        <td><%= number_with_delimiter(trace.total_tokens) %></td>
        <td><%= format_cost(trace.total_cost) %></td>
        <td><%= trace.iteration_count %></td>
        <td><%= trace.created_at.strftime("%Y-%m-%d %H:%M") %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<% if @traces.empty? %>
  <div class="empty">No traces found.</div>
<% end %>
