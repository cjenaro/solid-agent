<h1>Trace #<%= @trace.id %> <span class="badge badge-<%= @trace.status %>"><%= @trace.status %></span></h1>

<%# ── Summary Cards ── %>
<div class="stat-cards" style="margin-bottom:1.5rem;">
  <div class="stat-card">
    <div class="label">Duration</div>
    <div class="value"><%= @trace.duration ? format_duration(@trace.duration) : '—' %></div>
  </div>
  <div class="stat-card">
    <div class="label">Iterations</div>
    <div class="value"><%= @trace.total_iterations %></div>
  </div>
  <div class="stat-card">
    <div class="label">Tokens (in / out)</div>
    <div class="value"><%= number_with_delimiter(@trace.total_tokens) %></div>
    <div class="sub" style="font-size:0.75rem;color:#64748b;margin-top:0.125rem;"><%= number_with_delimiter(@trace.usage['input_tokens'] || 0) %> / <%= number_with_delimiter(@trace.usage['output_tokens'] || 0) %></div>
  </div>
  <div class="stat-card">
    <div class="label">Cost</div>
    <div class="value"><%= format_cost(@trace.total_cost) %></div>
    <% if @trace.model_name.present? %>
      <div class="sub" style="font-size:0.75rem;color:#64748b;margin-top:0.125rem;"><%= @trace.model_name %></div>
    <% end %>
  </div>
</div>

<%# ── Tool Summary ── %>
<% tool_summary = @trace.tool_summary %>
<% if tool_summary.any? %>
<div class="detail" style="margin-bottom:1.5rem;">
  <h2 style="margin-bottom:0.5rem;">Tool Calls</h2>
  <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
    <% tool_summary.sort_by { |_, v| -v }.each do |name, count| %>
      <span class="tool-pill">
        <span class="tool-pill-icon">&#x1F527;</span>
        <%= name %> <span class="tool-pill-count"><%= count %></span>
      </span>
    <% end %>
  </div>
</div>
<% end %>

<%# ── Child Traces Summary ── %>
<% if @trace.child_traces.any? %>
<div class="detail" style="margin-bottom:1.5rem;">
  <h2 style="margin-bottom:0.5rem;">Delegated Runs (<%= @trace.child_traces.count %>)</h2>
  <table style="box-shadow:none;border:1px solid #e2e8f0;border-radius:0.375rem;overflow:hidden;">
    <thead>
      <tr>
        <th>ID</th>
        <th>Agent</th>
        <th>Status</th>
        <th>Duration</th>
        <th>Tokens</th>
        <th>Cost</th>
      </tr>
    </thead>
    <tbody>
      <% @trace.child_traces.each do |ct| %>
        <tr>
          <td><%= link_to ct.id, solid_agent.trace_path(ct) %></td>
          <td><%= ct.agent_class %></td>
          <td><span class="badge badge-<%= ct.status %>"><%= ct.status %></span></td>
          <td><%= ct.duration ? format_duration(ct.duration) : '—' %></td>
          <td><%= number_with_delimiter(ct.total_tokens) %></td>
          <td><%= format_cost(ct.total_cost) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>

<%# ── Details ── %>
<div class="detail">
  <dl>
    <dt>Agent</dt>
    <dd><%= @trace.agent_class %></dd>
    <% if @trace.otel_trace_id.present? %>
      <dt>Trace ID</dt>
      <dd>
        <span class="otel-id" title="<%= @trace.otel_trace_id %>" data-copy="<%= @trace.otel_trace_id %>">
          <%= truncate_id(@trace.otel_trace_id) %>
        </span>
      </dd>
    <% end %>
    <% if @trace.otel_span_id.present? %>
      <dt>Root Span</dt>
      <dd>
        <span class="otel-id" title="<%= @trace.otel_span_id %>" data-copy="<%= @trace.otel_span_id %>">
          <%= truncate_id(@trace.otel_span_id) %>
        </span>
      </dd>
    <% end %>
    <dt>Input</dt>
    <dd><%= @trace.input %></dd>
    <% if @trace.output.present? %>
      <dt>Output</dt>
      <dd><%= @trace.output %></dd>
    <% end %>
    <% if @trace.error.present? %>
      <dt>Error</dt>
      <dd style="color: #991b1b"><%= @trace.error %></dd>
    <% end %>
    <% if @trace.started_at %>
      <dt>Started</dt>
      <dd><%= @trace.started_at.strftime("%Y-%m-%d %H:%M:%S") %></dd>
    <% end %>
    <% if @trace.completed_at %>
      <dt>Completed</dt>
      <dd><%= @trace.completed_at.strftime("%Y-%m-%d %H:%M:%S") %></dd>
    <% end %>
    <dt>Conversation</dt>
    <dd><%= link_to "##{@trace.conversation_id}", solid_agent.conversation_path(@trace.conversation) %></dd>
    <% if %w[running pending].include?(@trace.status) %>
      <dt>Actions</dt>
      <dd><%= button_to "Cancel", solid_agent.update_status_trace_path(@trace), params: { status: 'cancelled' }, method: :patch, class: "btn-cancel", form: { style: "display:inline-block;" } %></dd>
    <% elsif @trace.status == 'paused' %>
      <dt>Actions</dt>
      <dd><%= button_to "Resume", solid_agent.update_status_trace_path(@trace), params: { status: 'running' }, method: :patch, class: "btn-cancel", form: { style: "display:inline-block;" } %></dd>
    <% end %>
  </dl>
</div>

<h2>Spans</h2>
<% root_spans = @trace.spans.select { |s| s.parent_span_id.nil? }.sort_by(&:created_at) %>
<% if root_spans.any? %>
  <div class="tree">
    <% root_spans.each do |span| %>
      <%= render_span_tree(span, 0) %>
    <% end %>
    <% @trace.child_traces.each do |child| %>
      <%= render_trace_tree(child, 1) %>
    <% end %>
  </div>
<% else %>
  <div class="empty">No spans recorded.</div>
<% end %>
